# STT provider: dummy | whisper_api | whisper_local
STT_PROVIDER=dummy

# LLM provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (local LLM - default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (if using whisper_api STT or openai LLM)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (if using anthropic LLM)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Database (SQLite default, change to postgres for production)
DATABASE_URL=sqlite+aiosqlite:///./langtutor.db

# Default target language
DEFAULT_LANGUAGE=en
